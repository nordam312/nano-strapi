{
  "name": "nano-strapi",
  "version": "0.1.0",
  "description": "A tiny full-stack plugin framework re-implementing Strapi's architecture: a Node server (DI container, plugin loader, declarative routes, onion middleware) and a React admin (StrapiApp-style lifecycle + registries) with Vite HMR.",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server.ts",
    "dev:admin": "vite",
    "build:admin": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "framework",
    "plugin-system",
    "dependency-injection",
    "middleware",
    "react",
    "vite",
    "full-stack",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  }
}
